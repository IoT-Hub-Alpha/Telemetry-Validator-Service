# Django
DJANGO_SECRET_KEY=change-me-to-a-real-secret-key
VALIDATOR_DEBUG=false

# Kafka — Topics
KAFKA_TOPIC_TELEMETRY_RAW=telemetry.raw
KAFKA_TOPIC_TELEMETRY_CLEAN=telemetry.clean
KAFKA_TOPIC_TELEMETRY_DLQ=telemetry.dlq
KAFKA_CONSUMER_GROUP=telemetry-validator
KAFKA_REQUEST_TIMEOUT_MS=30000

# Consumer tuning
CONSUMER_BATCH_SIZE=100
CONSUMER_POLL_TIMEOUT=1.0

# Redis (if Redis-Service has REDIS_PASSWORD set, include it in the URL)
# Format: redis://:<password>@<host>:<port>/<db>
REDIS_URL=redis://:redis123@redis:6379/0
SCHEMA_CACHE_TTL_SECONDS=300
DEVICE_CACHE_TTL_SECONDS=600

# Device API (internal HTTP)
DEVICE_API_BASE_URL=http://web:8000/api
DEVICE_API_TIMEOUT_SECONDS=5.0

# Metrics
METRICS_PORT=9103
